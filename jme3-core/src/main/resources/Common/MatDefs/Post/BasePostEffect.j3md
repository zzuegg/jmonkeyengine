MaterialDef BasePostEffect {
    MaterialParameters {
        Int BoundDrawBuffer
        Int NumSamples
        Texture2D Texture
    }
    Technique {
        VertexShader   GLSL300 GLSL150 GLSL100 : Common/MatDefs/Post/Post.vert
        FragmentShader GLSL300 GLSL150 GLSL100 : Common/MatDefs/Post/PostPassthrough.frag
        WorldParameters {
        }
        Defines {
            BOUND_DRAW_BUFFER: BoundDrawBuffer
            RESOLVE_MS : NumSamples
        }
    }
}
