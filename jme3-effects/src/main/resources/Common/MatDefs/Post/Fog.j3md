MaterialDef Fade : Common/MatDefs/Post/BasePostEffect.j3md {
    MaterialParameters {
        Int NumSamplesDepth
        Texture2D DepthTexture
        Vector4 FogColor
        Float FogDensity
        Float FogDistance
    }
    Technique {
        FragmentShader GLSL300 GLSL150 GLSL100 : Common/MatDefs/Post/Fog.frag
        Defines {
            RESOLVE_DEPTH_MS : NumSamplesDepth
        }
    }
}
