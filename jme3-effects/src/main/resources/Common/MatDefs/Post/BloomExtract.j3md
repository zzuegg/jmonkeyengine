MaterialDef Bloom : Common/MatDefs/Post/BasePostEffect.j3md {
    MaterialParameters {
        Float ExposurePow
        Float ExposureCutoff
        Boolean Extract
        Texture2D GlowMap
    }
    Technique {
        FragmentShader GLSL300 GLSL150 GLSL100 : Common/MatDefs/Post/bloomExtract.frag
        Defines {
            HAS_GLOWMAP : GlowMap
            DO_EXTRACT : Extract
        }
    }
}
