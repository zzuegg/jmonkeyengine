MaterialDef KHRToneMap : Common/MatDefs/Post/BasePostEffect.j3md {
    MaterialParameters {
        Int NumSamplesDepth
        Vector3 Gamma
        Vector3 Exposure
    }
    Technique {
        FragmentShader GLSL300 GLSL150 GLSL100 : Common/MatDefs/Post/KHRToneMap.frag
        Defines {
            NUM_SAMPLES : NumSamples
        }
    }
}
